diff --git a/public/assets/styles/hcm-theme.scss b/public/assets/styles/hcm-theme.scss
new file mode 100644
index 00000000..bbcbcadf
--- /dev/null
+++ b/public/assets/styles/hcm-theme.scss
@@ -0,0 +1,186 @@
+// HCM brand theme overrides.
+// Kept in a single file and imported last so it survives upstream Fider rebases.
+// Regenerate hcm-theme.patch after edits: `git diff main..hcm-theme > hcm-theme.patch`
+
+$hcm-green-100: #00f7a5;
+$hcm-green-200: #008859;
+$hcm-green-300: #004c2c;
+$hcm-bg: #111111;
+$hcm-bg-alt: #161616;
+$hcm-surface: #1e1e1e;
+$hcm-submit-bg: #0d1f17;
+$hcm-vote-border: #1e3329;
+
+// 1. Submit area on the home page -------------------------------------------
+// The native control is a single <button> with the placeholder text inside.
+// CSS-only treatment: add a label above and an inline "Submit" pill on the right.
+#p-home .p-home__add-idea-btn {
+  position: relative;
+  background-color: $hcm-submit-bg !important;
+  border: 2px solid $hcm-green-200 !important;
+  color: $hcm-green-100 !important;
+  padding-top: 32px;
+  padding-right: 120px;
+  box-shadow: none;
+
+  &::before {
+    content: "Submit your idea";
+    position: absolute;
+    top: 8px;
+    left: 16px;
+    color: $hcm-green-100;
+    font-size: 12px;
+    font-weight: 600;
+    text-transform: uppercase;
+    letter-spacing: 0.04em;
+  }
+
+  &::after {
+    content: "Submit";
+    position: absolute;
+    right: 12px;
+    top: 50%;
+    transform: translateY(-25%);
+    background-color: $hcm-green-200;
+    color: #ffffff;
+    padding: 10px 18px;
+    border-radius: 8px;
+    font-weight: 600;
+    font-size: 14px;
+    line-height: 1;
+    pointer-events: none;
+  }
+
+  &:hover {
+    background-color: lighten($hcm-submit-bg, 3%) !important;
+    border-color: $hcm-green-100 !important;
+    box-shadow: 0 0 0 3px rgba($hcm-green-100, 0.15);
+
+    &::after {
+      background-color: $hcm-green-300;
+    }
+  }
+
+  &:focus {
+    outline-color: $hcm-green-100 !important;
+  }
+
+  // The plus icon and placeholder text inside the button.
+  .p-home__add-idea-icon {
+    color: $hcm-green-100 !important;
+  }
+  span {
+    color: rgba($hcm-green-100, 0.85);
+  }
+
+  // Dark-mode override that previously set a gray background.
+  body[data-theme="dark"] & {
+    background-color: $hcm-submit-bg !important;
+  }
+}
+
+// 2. Vote buttons ------------------------------------------------------------
+.c-vote-counter__button {
+  background-color: $hcm-submit-bg !important;
+  border-color: $hcm-vote-border !important;
+  color: $hcm-green-100 !important;
+
+  .c-vote-counter__icon,
+  .c-vote-counter__count {
+    color: $hcm-green-100 !important;
+  }
+
+  &:hover {
+    background-color: lighten($hcm-submit-bg, 4%) !important;
+    border-color: $hcm-green-100 !important;
+    color: $hcm-green-100 !important;
+
+    .c-vote-counter__icon {
+      color: $hcm-green-100 !important;
+    }
+  }
+
+  &--voted {
+    background-color: $hcm-green-300 !important;
+    border-color: $hcm-green-100 !important;
+    color: $hcm-green-100 !important;
+
+    .c-vote-counter__icon,
+    .c-vote-counter__count {
+      color: $hcm-green-100 !important;
+    }
+
+    &:hover {
+      background-color: darken($hcm-green-300, 3%) !important;
+      border-color: $hcm-green-100 !important;
+    }
+  }
+}
+
+// 3. Header ------------------------------------------------------------------
+#c-header {
+  border-left: 4px solid $hcm-green-200 !important;
+
+  h1.text-header {
+    color: #ffffff !important;
+  }
+
+  // Light-mode header has a white background; in dark mode keep contrast.
+  body[data-theme="dark"] & {
+    h1.text-header {
+      color: #ffffff !important;
+    }
+  }
+}
+
+// 4. Status tags -------------------------------------------------------------
+// Fider has no stylesheet for .c-status-label, just the class names.
+// Provide one matching the brand palette.
+.c-status-label {
+  display: inline-block;
+  padding: 4px 10px;
+  border-radius: 999px;
+  font-size: 11px;
+  font-weight: 600;
+  letter-spacing: 0.03em;
+  text-transform: uppercase;
+  line-height: 1.2;
+
+  // Default / "open" stays neutral.
+  background-color: var(--colors-gray-100);
+  color: var(--colors-gray-700);
+  border: 1px solid var(--colors-gray-200);
+
+  &--planned,
+  &--started {
+    background-color: $hcm-submit-bg;
+    color: $hcm-green-200;
+    border-color: rgba($hcm-green-200, 0.5);
+  }
+
+  &--completed {
+    background-color: $hcm-green-300;
+    color: $hcm-green-100;
+    border-color: $hcm-green-200;
+  }
+
+  &--declined,
+  &--duplicate {
+    background-color: var(--colors-gray-100);
+    color: var(--colors-gray-700);
+    border-color: var(--colors-gray-300);
+  }
+}
+
+// 5. Primary buttons globally -----------------------------------------------
+.c-button--primary {
+  background-color: $hcm-green-200 !important;
+  border-color: $hcm-green-200 !important;
+  color: #ffffff !important;
+
+  &:hover {
+    background-color: $hcm-green-300 !important;
+    border-color: $hcm-green-300 !important;
+    color: #ffffff !important;
+  }
+}
